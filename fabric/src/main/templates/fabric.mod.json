{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "NeroCreatures - multiloader build (Fabric).",
  "authors": ["${mod_authors}"],
  "license": "${mod_license}",
  "accessWidener": "nerocreatures.accesswidener",
  "environment": "*",
  "entrypoints": {
    "main": ["za.co.neroland.nerocreatures.fabric.NeroCreaturesFabric"],
    "client": ["za.co.neroland.nerocreatures.fabric.NeroCreaturesFabricClient"]
  },
  "mixins": [
    "nerocreatures-common.mixins.json",
    "nerocreatures.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
